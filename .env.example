DATABASE_URL="postgresql://user:pass@host:port/dbname?sslmode=require&pgbouncer=true"

# JWT
JWT_SECRET="generate-a-random-secret-here"
JWT_EXPIRES_IN="7d"

# Zalo Mini App 
# Lấy từ https://developers.zalo.me → App của bạn → Thông tin ứng dụng
ZALO_APP_ID=""
ZALO_APP_SECRET=""

# TEST MODE
# Set to "true" to use mock data instead of calling real Zalo APIs
ZALO_MOCK_MODE="false"
